# Database Configuration
# SQLite for development
DATABASE_URL="file:./prisma/dev.db"

# For PostgreSQL in production, use:
# DATABASE_URL="postgresql://user:password@localhost:5432/vendor_onboarding?schema=public"

# Server Configuration
PORT=3000
NODE_ENV=development

# AI Configuration (Required)
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_here

# Use llama-3.1-8b-instant for fast local testing.
# Switch to llama-3.3-70b-versatile for the final demo recording (slower
# but higher quality output) — see PRD Technology Stack section.
GROQ_MODEL=llama-3.1-8b-instant

# Connector Configuration (Optional)
# Telegram Bot Token - Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# API Base URL for connectors
API_BASE_URL=http://localhost:3000

# Enable/disable mock ERP connector for testing
ENABLE_MOCK_ERP=false

# Connector Authentication (Production)
# CONNECTOR_SECRET=your_secret_token_here
